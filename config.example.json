{
  "_max_request_bytes_comment": "Max request body bytes for /v1/* and admin write routes. Default: 10485760 (10 MiB). Exceeding returns HTTP 413.",
  "max_request_bytes": 10485760,
  "strategy": {
    "mode": "fallback",
    "_unpriced_strategy_comment": "cost-optimized only: fallback (default) | skip | allow",
    "_comment": "mode: single | fallback | loadbalance | conditional | content-based | ab-test | least-latency | cost-optimized"
  },
  "_conditional_example": {
    "strategy": {
      "mode": "conditional",
      "conditions": [
        { "key": "model", "value": "gpt-4o",                      "target_key": "openai" },
        { "key": "model", "value": "claude-sonnet-4-6",  "target_key": "anthropic" }
      ]
    }
  },
  "_content_based_example": {
    "strategy": {
      "mode": "content-based",
      "content_conditions": [
        { "type": "prompt_regex",       "value": "(?i)\\b(code|function|class|implement)\\b", "target_key": "deepseek" },
        { "type": "prompt_contains",    "value": "translate",   "target_key": "gemini" },
        { "type": "prompt_not_contains","value": "confidential","target_key": "openai" }
      ]
    }
  },
  "_ab_test_example": {
    "strategy": {
      "mode": "ab-test",
      "ab_variants": [
        { "target_key": "openai",    "weight": 70, "label": "control" },
        { "target_key": "anthropic", "weight": 30, "label": "challenger" }
      ]
    }
  },
  "targets": [
    {
      "virtual_key": "openai",
      "retry": {
        "attempts": 3,
        "on_status_codes": [429, 502, 503],
        "initial_backoff_ms": 100
      }
    },
    {
      "virtual_key": "anthropic",
      "circuit_breaker": {
        "failure_threshold": 5,
        "success_threshold": 1,
        "timeout": "30s"
      }
    },
    {
      "virtual_key": "xai"
    },
    {
      "virtual_key": "gemini"
    },
    {
      "virtual_key": "mistral"
    },
    {
      "virtual_key": "groq"
    },
    {
      "virtual_key": "together"
    },
    {
      "virtual_key": "cohere"
    },
    {
      "virtual_key": "deepseek"
    },
    {
      "virtual_key": "perplexity"
    },
    {
      "virtual_key": "fireworks"
    },
    {
      "virtual_key": "ai21"
    },
    {
      "virtual_key": "replicate"
    },
    {
      "virtual_key": "bedrock"
    },
    {
      "virtual_key": "azure-openai"
    },
    {
      "virtual_key": "azure-foundry"
    },
    {
      "virtual_key": "vertex-ai"
    },
    {
      "virtual_key": "hugging-face"
    },
    {
      "virtual_key": "ollama"
    },
    {
      "virtual_key": "ollama-cloud"
    },
    {
      "virtual_key": "cerebras"
    },
    {
      "virtual_key": "cloudflare"
    },
    {
      "virtual_key": "databricks"
    },
    {
      "virtual_key": "deepinfra"
    },
    {
      "virtual_key": "moonshot"
    },
    {
      "virtual_key": "novita"
    },
    {
      "virtual_key": "nvidia-nim"
    },
    {
      "virtual_key": "openrouter"
    },
    {
      "virtual_key": "qwen"
    },
    {
      "virtual_key": "sambanova"
    }
  ],
  "aliases": {
    "fast": "gpt-4o-mini",
    "smart": "claude-sonnet-4-6",
    "cheap": "gemini-2.5-flash",
    "code": "deepseek-coder"
  },
  "plugins": [
    {
      "name": "word-filter",
      "type": "guardrail",
      "stage": "before_request",
      "enabled": true,
      "config": {
        "blocked_words": ["password", "secret"],
        "case_sensitive": false
      }
    },
    {
      "name": "max-token",
      "type": "guardrail",
      "stage": "before_request",
      "enabled": true,
      "config": {
        "max_tokens": 4096,
        "max_messages": 50,
        "max_input_length": 0
      }
    },
    {
      "name": "response-cache",
      "type": "transform",
      "stage": "before_request",
      "enabled": false,
      "config": {
        "max_age": 300,
        "max_entries": 1000
      }
    },
    {
      "name": "request-logger",
      "type": "logging",
      "stage": "before_request",
      "enabled": true,
      "config": {
        "level": "info",
        "persist": false,
        "backend": "sqlite",
        "dsn": "ferrogw-requests.db"
      }
    },
    {
      "name": "rate-limit",
      "type": "guardrail",
      "stage": "before_request",
      "enabled": false,
      "config": {
        "requests_per_second": 100,
        "burst": 100,
        "key_rpm": 60,
        "user_rpm": 30
      }
    },
    {
      "name": "budget",
      "type": "guardrail",
      "stage": "before_request",
      "enabled": false,
      "config": {
        "store_id": "default",
        "spend_limit_usd": 10.0,
        "input_per_m_tokens": 3.0,
        "output_per_m_tokens": 15.0,
        "max_keys": 10000
      }
    }
  ],
  "mcp_servers": [
    {
      "name": "filesystem",
      "url": "http://localhost:3001/mcp",
      "timeout_seconds": 10,
      "max_call_depth": 3
    },
    {
      "name": "database",
      "url": "https://mcp-db.internal/mcp",
      "headers": {
        "Authorization": "Bearer ${MCP_DB_TOKEN}"
      },
      "allowed_tools": ["query_readonly", "list_tables"],
      "timeout_seconds": 15,
      "max_call_depth": 5
    },
    {
      "name": "web-search",
      "url": "https://mcp-search.example.com/mcp",
      "allowed_tools": ["web_search", "web_read"],
      "timeout_seconds": 20
    }
  ],
  "observability": {
    "tracing": {
      "enabled": true,
      "endpoint": "",
      "protocol": "grpc",
      "service_name": "ferrogw",
      "sample_ratio": 1.0,
      "privacy_level": "metadata",
      "shutdown_grace": "10s",
      "headers": {}
    },
    "exporters": []
  }
}
