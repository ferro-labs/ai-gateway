# Ferro Labs AI Gateway — Environment Variables
# Copy and set values in your environment (DO NOT commit real secrets).
#
# Local dev:  source .env && ferrogw serve
# Docker:     docker run --env-file .env ferrolabs/ai-gateway
# Kubernetes: use K8s Secrets with envFrom

# ── Master Key (required for dashboard/admin) ─────
# Generate with: ferrogw init
MASTER_KEY=

# ── Providers (set at least one) ───────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=
# COHERE_API_KEY=
# TOGETHER_API_KEY=
# XAI_API_KEY=
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODELS=llama3,codellama

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure Foundry
# AZURE_FOUNDRY_API_KEY=
# AZURE_FOUNDRY_ENDPOINT=
# AZURE_FOUNDRY_API_VERSION=

# AWS Bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Vertex AI
# VERTEX_AI_PROJECT_ID=
# VERTEX_AI_REGION=us-central1
# VERTEX_AI_API_KEY=
# VERTEX_AI_SERVICE_ACCOUNT_JSON=

# Hugging Face
# HUGGING_FACE_API_KEY=
# HUGGING_FACE_ENDPOINT=

# ── Server ─────────────────────────────────────────
# PORT=8080
# GATEWAY_CONFIG=config.yaml
# LOG_LEVEL=info
# LOG_FORMAT=json
# CORS_ORIGINS=http://localhost:3000

# ── Storage (default: in-memory) ───────────────────
# Recommended: sqlite for local dev, postgres for production
# API_KEY_STORE_BACKEND=sqlite
# API_KEY_STORE_DSN=data/keys.db
# CONFIG_STORE_BACKEND=sqlite
# CONFIG_STORE_DSN=data/config.db
# REQUEST_LOG_STORE_BACKEND=sqlite
# REQUEST_LOG_STORE_DSN=data/logs.db

# ── Rate Limiting ──────────────────────────────────
# RATE_LIMIT_RPS=100
# RATE_LIMIT_BURST=200

# ── Deprecated (use MASTER_KEY instead) ────────────
# ADMIN_BOOTSTRAP_KEY=
# ADMIN_BOOTSTRAP_READ_ONLY_KEY=
# ADMIN_BOOTSTRAP_ENABLED=true

# ── Test-only ──────────────────────────────────────
# FERROGW_TEST_POSTGRES_DSN=postgres://user:pass@localhost:5432/ferrogw_test?sslmode=require
